# ============================================================
#  Trakvora — Environment Variables Template
#  Copy to .env (dev) or .env.prod (production) and fill in.
#  Never commit a file with real secrets.
#  Generate SECRET_KEY with: openssl rand -hex 32
# ============================================================

# --- Database ---
POSTGRES_USER=trakvora
POSTGRES_PASSWORD=CHANGE_ME
POSTGRES_DB=trakvora
DATABASE_URL=postgresql+asyncpg://trakvora:CHANGE_ME@db:5432/trakvora

# --- Auth ---
SECRET_KEY=CHANGE_ME_run_openssl_rand_hex_32
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# --- CORS (comma-separated list of allowed origins) ---
CORS_ORIGINS=https://trakvora.com

# --- Payment: Flutterwave ---
FLUTTERWAVE_SECRET_KEY=CHANGE_ME
FLUTTERWAVE_PUBLIC_KEY=CHANGE_ME
FLUTTERWAVE_WEBHOOK_SECRET=CHANGE_ME
FLUTTERWAVE_REDIRECT_URL=https://trakvora.com/shipper/wallet
FLUTTERWAVE_TRANSFER_CALLBACK_URL=https://api.trakvora.com/webhooks/flutterwave

# --- KYC: Smile Identity ---
SMILE_IDENTITY_API_KEY=CHANGE_ME
SMILE_IDENTITY_PARTNER_ID=CHANGE_ME

# --- SMS: AfricasTalking ---
AFRICASTALKING_API_KEY=CHANGE_ME
AFRICASTALKING_USERNAME=CHANGE_ME

# --- Email: Resend (primary transactional) ---
RESEND_API_KEY=CHANGE_ME

# --- Email: SMTP (fallback) ---
SMTP_HOST=smtp.hmailplus.com
SMTP_PORT=587
SMTP_USERNAME=CHANGE_ME
SMTP_PASSWORD=CHANGE_ME
SMTP_FROM_EMAIL=noreply@trakvora.com
SMTP_TLS=true

# --- Google OAuth ---
GOOGLE_CLIENT_ID=CHANGE_ME

# --- Frontend (served via nginx in prod, only needed for build step) ---
VITE_API_URL=https://trakvora.com/api
VITE_GOOGLE_MAPS_API_KEY=CHANGE_ME
VITE_GOOGLE_CLIENT_ID=CHANGE_ME

# --- Support contacts ---
SUPPORT_WHATSAPP=+254700000000
SUPPORT_EMAIL=support@trakvora.com

# --- KRA eTIMS (Kenya Tax) ---
KRA_PIN=CHANGE_ME
ETIMS_USERNAME=CHANGE_ME
ETIMS_PASSWORD=CHANGE_ME
ETIMS_BRANCH_ID=00
ETIMS_SANDBOX=false

# --- Environment ---
ENVIRONMENT=production

# --- Monitoring: Grafana ---
GRAFANA_ADMIN_PASSWORD=CHANGE_ME

# --- Backups ---
# Directory on host where pg_dump files are stored
BACKUP_DIR=/backups/postgres
# Days to keep local backups before deletion
BACKUP_RETENTION_DAYS=30
# Optional: rclone remote path e.g. "s3:trakvora-backups"
BACKUP_S3_BUCKET=
# Optional: passphrase for GPG encryption of backup files
BACKUP_GPG_PASSPHRASE=
